# ============================================================
# CloudFinOps-Env — Environment Configuration
# ============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below
# 3. Run:  python inference.py
#
# That's it. Everything reads from this file automatically.
# ============================================================

# ── LLM Provider Toggle ──────────────────────────────────────
# Set to "groq" to use Groq, or "huggingface" to use HF Router.
# Default: huggingface
LLM_PROVIDER=groq

# ── Groq Configuration (used when LLM_PROVIDER=groq) ────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL_NAME=llama-3.3-70b-versatile

# ── Hugging Face Configuration (used when LLM_PROVIDER=huggingface)
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=openai/gpt-oss-20b
HF_TOKEN=hf_your_token_here

# ── Environment Server URL (override if deployed remotely) ───
# ENV_BASE_URL=http://localhost:8000
